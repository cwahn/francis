{
  "source": {
    "url": "http://localhost:13100",
    "base_query": "{service_name=\"organon-core\"}"
  },
  "poll_interval_ms": 3000,
  "ingestion_slack_ms": 10000,
  "hypothesis": {
    "All": {
      "binding": "root",
      "predictions": [
        {
          "Unit": {
            "binding": "server_started",
            "pattern": "|= \"provision started\"",
            "timeout_ms": 90000
          }
        },
        {
          "Unit": {
            "binding": "governance_ready",
            "pattern": "|= \"governance registered\"",
            "after": "server_started",
            "timeout_ms": 60000
          }
        },
        {
          "Unit": {
            "binding": "all_spawned",
            "pattern": "|= \"all services spawned\"",
            "after": "governance_ready",
            "timeout_ms": 60000
          }
        },
        {
          "Unit": {
            "binding": "conn_accepted",
            "pattern": "|= \"accept_and_prepare: connection accepted\" | regexp \"conn_id=(?P<conn_id>[a-f0-9-]+)\"",
            "after": "all_spawned",
            "timeout_ms": 120000
          }
        },
        {
          "Unit": {
            "binding": "first_bi",
            "pattern": "|= \"accept_bi: got bi-stream\" |= \"${conn_id}\"",
            "after": "conn_accepted",
            "timeout_ms": 60000
          }
        },
        {
          "Unit": {
            "binding": "first_import",
            "pattern": "|= \"received Import bi-stream\" |= \"${conn_id}\"",
            "after": "first_bi",
            "timeout_ms": 30000
          }
        },
        {
          "Any": {
            "binding": "second_bi_outcome",
            "after": "first_import",
            "predictions": [
              {
                "Unit": {
                  "binding": "second_bi_received",
                  "pattern": "|= \"accept_bi: got bi-stream\" |= \"${conn_id}\"",
                  "timeout_ms": 120000
                }
              },
              {
                "Unit": {
                  "binding": "conn_error",
                  "pattern": "|= \"failed to accept bi-stream\" |= \"${conn_id}\"",
                  "timeout_ms": 120000
                }
              }
            ]
          }
        }
      ]
    }
  }
}
